# Copy to .env.local (app) or .env.test (Playwright / DB tests)

# Recommended (server-only names; not bundled to the browser):
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Legacy: if unset, middleware/API fall back to these (same values as above are OK during migration):
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Test User (optional)
TEST_USER_EMAIL=test@example.com
TEST_USER_PASSWORD=testpassword123

# Test Base URL (optional, defaults to http://localhost:3000)
TEST_BASE_URL=http://localhost:3000
