# Feedback Collector 环境变量配置示例
# 复制此文件为 .env 并填写实际值

# AI 服务配置
FC_AI_API_KEY=your_api_key_here
FC_AI_MODEL=deepseek-chat
FC_AI_BASE_URL=https://api.deepseek.com/v1

# 微信配置
FC_WECHAT_WXID=your_wxid_here
FC_WECHAT_DB_PATH=/path/to/wechat/db

# 飞书配置
FC_FEISHU_APP_ID=your_app_id
FC_FEISHU_APP_SECRET=your_app_secret
FC_FEISHU_TABLE_ID=your_table_id

# Notion 配置
FC_NOTION_TOKEN=your_notion_token
FC_NOTION_DATABASE_ID=your_database_id

# 配置文件路径（可选）
# FC_CONFIG=/path/to/config.yaml
